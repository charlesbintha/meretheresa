APP_NAME="Groupe Scolaire Mère Thérèsa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ==============================================================
# Base de données — SQLite suffit pour le site statique actuel.
# Passez en mysql uniquement si vous ajoutez du stockage (ex. liste newsletter).
# ==============================================================
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=mere_theresa
# DB_USERNAME=root
# DB_PASSWORD=

# ==============================================================
# SMTP — envoi des emails (formulaire contact + newsletter)
# Remplir avec les identifiants SMTP Hostinger (ou autre provider).
# ==============================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=contact@votre-domaine.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="contact@votre-domaine.com"
MAIL_FROM_NAME="${APP_NAME}"

# Destinataires internes :
#   - MAIL_CONTACT_TO    : où arrivent les messages du formulaire /contact
#   - MAIL_NEWSLETTER_TO : où arrivent les notifs d'inscription newsletter
# Si non renseignés, tout part sur MAIL_FROM_ADDRESS.
MAIL_CONTACT_TO=gardebambinos@gmail.com
MAIL_NEWSLETTER_TO=gardebambinos@gmail.com
